{
    "name": "aiarmada/filament-cashier",
    "description": "Unified Filament admin interface for multi-gateway billing management",
    "license": "MIT",
    "keywords": [
        "filament",
        "cashier",
        "billing",
        "subscriptions",
        "stripe",
        "chip",
        "payments",
        "multi-gateway"
    ],
    "homepage": "https://github.com/aiarmada/commerce",
    "authors": [
        {
            "name": "AIArmada",
            "email": "support@aiarmada.com"
        }
    ],
    "require": {
        "aiarmada/cashier": "self.version",
        "filament/filament": "^5.0"
    },
    "suggest": {
        "laravel/cashier": "Required for Stripe gateway features",
        "aiarmada/cashier-chip": "Required for CHIP gateway features",
        "aiarmada/filament-cashier-chip": "Enhanced CHIP-specific UI"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentCashier\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\FilamentCashier\\FilamentCashierServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}