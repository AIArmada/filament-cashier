<?php

declare(strict_types=1);

namespace AIArmada\Tax\Tests\Unit\Settings;

use AIArmada\Tax\Settings\TaxSettings;
use AIArmada\Tax\Tests\TaxTestCase;

class TaxSettingsTest extends TaxTestCase
{
    public function test_settings_group(): void
    {
        $this->assertEquals('tax', TaxSettings::group());
    }

    public function test_calculate_tax_when_enabled(): void
    {
        $settings = new TaxSettings();
        $settings->enabled = true;
        $settings->defaultTaxRate = 10.0;

        $tax = $settings->calculateTax(10000); // $100.00

        $this->assertEquals(1000, $tax); // 10% of 10000 cents = 1000 cents
    }

    public function test_calculate_tax_when_disabled(): void
    {
        $settings = new TaxSettings();
        $settings->enabled = false;
        $settings->defaultTaxRate = 10.0;

        $tax = $settings->calculateTax(10000);

        $this->assertEquals(0, $tax);
    }

    public function test_extract_tax_when_enabled(): void
    {
        $settings = new TaxSettings();
        $settings->enabled = true;
        $settings->defaultTaxRate = 10.0;

        $tax = $settings->extractTax(11000); // $110.00 inclusive

        $this->assertEquals(1000, $tax); // Extract 10% from 11000 = 1000 cents
    }

    public function test_extract_tax_when_disabled(): void
    {
        $settings = new TaxSettings();
        $settings->enabled = false;
        $settings->defaultTaxRate = 10.0;

        $tax = $settings->extractTax(11000);

        $this->assertEquals(0, $tax);
    }

    public function test_extract_tax_calculation(): void
    {
        $settings = new TaxSettings();
        $settings->enabled = true;
        $settings->defaultTaxRate = 8.75;

        // For 8.75% tax: divisor = 1 + 0.0875 = 1.0875
        // Tax amount = 11000 / 1.0875 - 11000 = wait, let me calculate properly
        // Actually: tax = inclusive_price * (tax_rate / (100 + tax_rate))
        // tax = 11000 * (8.75 / 108.75) ≈ 11000 * 0.08046 ≈ 885

        $tax = $settings->extractTax(11000);

        $this->assertEquals(885, $tax); // Approximately 885 cents
    }

    public function test_calculate_tax_with_different_rates(): void
    {
        $settings10 = new TaxSettings();
        $settings10->enabled = true;
        $settings10->defaultTaxRate = 10.0;

        $settings20 = new TaxSettings();
        $settings20->enabled = true;
        $settings20->defaultTaxRate = 20.0;

        $this->assertEquals(1000, $settings10->calculateTax(10000)); // 10%
        $this->assertEquals(2000, $settings20->calculateTax(10000)); // 20%
    }
}