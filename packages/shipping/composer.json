{
    "name": "aiarmada/shipping",
    "description": "Multi-carrier shipping abstraction layer for Laravel commerce applications",
    "license": "MIT",
    "homepage": "https://github.com/aiarmada/commerce",
    "support": {
        "issues": "https://github.com/aiarmada/commerce/issues",
        "source": "https://github.com/aiarmada/commerce"
    },
    "require": {
        "aiarmada/commerce-support": "self.version",
        "spatie/laravel-data": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\Shipping\\": "src/",
            "AIArmada\\Shipping\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\Shipping\\ShippingServiceProvider"
            ],
            "aliases": {
                "Shipping": "AIArmada\\Shipping\\Facades\\Shipping"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}