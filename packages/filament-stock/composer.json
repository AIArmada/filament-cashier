{
  "name": "aiarmada/filament-stock",
  "description": "A Filament v5 plugin for administering stock provided by the AIArmada stock package",
  "license": "MIT",
  "homepage": "https://github.com/aiarmada/commerce",
  "support": {
    "issues": "https://github.com/aiarmada/commerce/issues",
    "source": "https://github.com/aiarmada/commerce"
  },
  "require": {
    "aiarmada/stock": "self.version",
    "filament/filament": "^5.0"
  },
  "suggest": {
    "aiarmada/filament-cart": "Enables deep linking from stock reservations to cart records"
  },
  "autoload": {
    "psr-4": {
      "AIArmada\\FilamentStock\\": "src/",
      "AIArmada\\FilamentStock\\Database\\Factories\\": "database/factories/",
      "AIArmada\\FilamentStock\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AIArmada\\FilamentStock\\FilamentStockServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
